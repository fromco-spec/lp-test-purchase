# ───────────────────────────────────
# テストカード情報（必須）
# ───────────────────────────────────
TEST_CARD_NUMBER=
TEST_CARD_CVC=
TEST_CARD_HOLDER_NAME=

# 有効期限：通常は空欄でOK（実行時の今月・今年が自動入力される）
# 固定したい場合のみ記入。年は4桁推奨（例: 2030）
TEST_CARD_EXPIRY_MONTH=
TEST_CARD_EXPIRY_YEAR=

# ───────────────────────────────────
# テスト顧客情報（必須はドメインのみ）
# ───────────────────────────────────
# メアドのドメイン部分（@より右）。重複防止のため、ローカル部はランダム生成。
# 例: gmail.com / example.com / 自社ドメイン
TEST_EMAIL_DOMAIN=
TEST_EMAIL_TAG=autotest

# ───────────────────────────────────
# ダミー住所（任意。空欄ならデフォルト値）
# ───────────────────────────────────
TEST_POSTAL_CODE=1000001
TEST_PREFECTURE=東京都
TEST_CITY=千代田区
TEST_ADDRESS1=千代田1-1-1
TEST_ADDRESS2=テストビル999F

# ───────────────────────────────────
# Notion（DB作成・LP管理・実行履歴記録に使用）
# ───────────────────────────────────
# 内部インテグレーションのシークレット (secret_xxxxx... で始まる)
NOTION_TOKEN=

# 親ページのID（NotionページURL末尾の32文字）
# 例: https://www.notion.so/.../to-esella-359022d569d38030be25d25aa3f14730
#     → 359022d569d38030be25d25aa3f14730
NOTION_PARENT_PAGE_ID=

# セットアップスクリプト実行後に追記する（自動表示される）
NOTION_LP_DATABASE_ID=
NOTION_RUNS_DATABASE_ID=

# ───────────────────────────────────
# GitHub Actions（リモートトリガー用）
# ───────────────────────────────────
# リポジトリ "owner/repo" 形式
GITHUB_REPO=
# Personal Access Token (repoスコープ。設定 → Developer settings → Tokens)
GITHUB_TOKEN=
